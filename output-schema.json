{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "doctoral-ti-news-output",
  "title": "Doctoral TI News Finder — salida enriquecida",
  "description": "Esquema de salida para la skill 01-doctoral-ti-news. Usar null cuando un dato no esté verificado.",
  "type": "object",
  "required": [
    "meta",
    "resumen_ejecutivo",
    "hallazgos",
    "preguntas_doctorales_sugeridas",
    "riesgos_metodologicos",
    "vacios_investigacion"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "tema",
        "ventana_temporal",
        "fecha_generacion",
        "formato_solicitado",
        "total_hallazgos",
        "fuentes_utilizadas"
      ],
      "properties": {
        "tema": { "type": "string" },
        "ventana_temporal": { "type": "string" },
        "profundidad": {
          "type": "string",
          "enum": ["breve", "media", "profunda"]
        },
        "region": { "type": ["string", "null"] },
        "idioma_salida": { "type": "string", "default": "es" },
        "fecha_generacion": {
          "type": "string",
          "description": "ISO 8601, ej. 2026-06-11T14:30:00Z"
        },
        "formato_solicitado": {
          "type": "string",
          "enum": ["json", "texto", "ambos"]
        },
        "total_hallazgos": { "type": "integer", "minimum": 0 },
        "fuentes_utilizadas": {
          "type": "array",
          "items": { "type": "string" },
          "description": "APIs y sitios consultados con URL base"
        }
      }
    },
    "resumen_ejecutivo": {
      "type": "string",
      "description": "5-8 líneas de síntesis"
    },
    "hallazgos": {
      "type": "array",
      "items": { "$ref": "#/definitions/hallazgo" }
    },
    "preguntas_doctorales_sugeridas": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "riesgos_metodologicos": {
      "type": "array",
      "items": { "type": "string" }
    },
    "vacios_investigacion": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "hallazgo": {
      "type": "object",
      "required": [
        "ranking",
        "tema",
        "noticia",
        "evidencia_cientifica",
        "relevancia_doctoral",
        "nivel_confianza",
        "riesgos_sesgo"
      ],
      "properties": {
        "ranking": { "type": "integer", "minimum": 1 },
        "tema": { "type": "string" },
        "noticia": {
          "type": "object",
          "required": ["titulo", "fuente", "url", "fecha", "tipo"],
          "properties": {
            "titulo": { "type": "string" },
            "fuente": { "type": "string" },
            "url": { "type": ["string", "null"], "format": "uri" },
            "fecha": { "type": ["string", "null"] },
            "tipo": {
              "type": "string",
              "enum": [
                "noticia",
                "comunicado",
                "blog_institucional",
                "otro"
              ]
            }
          }
        },
        "evidencia_cientifica": {
          "type": ["object", "null"],
          "description": "null si la noticia no tiene paper vinculado verificable",
          "required": [
            "titulo",
            "doi",
            "url",
            "tipo_publicacion",
            "estado_publicacion",
            "fecha_publicacion",
            "fecha_precision",
            "revista_o_venue",
            "metricas_venue",
            "abstract_original",
            "abstract_simplificado",
            "puntos_importantes",
            "impactos",
            "autores",
            "creditos_contribucion",
            "open_access"
          ],
          "properties": {
            "titulo": { "type": ["string", "null"] },
            "doi": { "type": ["string", "null"] },
            "url": { "type": ["string", "null"], "format": "uri" },
            "tipo_publicacion": {
              "type": "string",
              "enum": [
                "journal-article",
                "preprint",
                "posted-content",
                "proceedings-article",
                "review-article",
                "systematic-review",
                "meta-analysis",
                "book-chapter",
                "report",
                "other"
              ]
            },
            "tipo_publicacion_etiqueta": {
              "type": "string",
              "description": "Etiqueta legible en español"
            },
            "estado_publicacion": {
              "type": "string",
              "enum": [
                "publicado",
                "preprint",
                "en_revision",
                "aceptado",
                "retractado",
                "desconocido"
              ]
            },
            "fecha_publicacion": { "type": ["string", "null"] },
            "fecha_precision": {
              "type": "string",
              "enum": ["dia", "mes", "anio", "desconocido"]
            },
            "revista_o_venue": {
              "type": "object",
              "required": [
                "nombre",
                "issn",
                "editorial",
                "pais",
                "indexacion"
              ],
              "properties": {
                "nombre": { "type": ["string", "null"] },
                "issn": { "type": ["string", "null"] },
                "editorial": { "type": ["string", "null"] },
                "pais": { "type": ["string", "null"] },
                "indexacion": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "metricas_venue": {
              "type": "object",
              "required": [
                "cuartil",
                "percentil",
                "fuente_metrica",
                "sjr",
                "impact_factor",
                "notas"
              ],
              "properties": {
                "cuartil": {
                  "type": "string",
                  "enum": ["Q1", "Q2", "Q3", "Q4", "no_confirmado"]
                },
                "percentil": {
                  "type": ["number", "null"],
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Percentil SJR u otra métrica comparable"
                },
                "fuente_metrica": {
                  "type": "string",
                  "enum": [
                    "scimago",
                    "jcr",
                    "doaj",
                    "openalex",
                    "no_disponible"
                  ]
                },
                "sjr": { "type": ["number", "null"] },
                "impact_factor": { "type": ["number", "null"] },
                "notas": { "type": "string" }
              }
            },
            "abstract_original": { "type": ["string", "null"] },
            "abstract_simplificado": {
              "type": ["string", "null"],
              "description": "Reescritura en lenguaje claro, máx. ~120 palabras"
            },
            "puntos_importantes": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "maxItems": 7
            },
            "impactos": {
              "type": "object",
              "required": ["cientifico", "tecnico", "social", "doctoral"],
              "properties": {
                "cientifico": { "type": "string" },
                "tecnico": { "type": "string" },
                "social": { "type": "string" },
                "doctoral": { "type": "string" }
              }
            },
            "autores": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "nombre",
                  "orcid",
                  "afiliacion",
                  "rol",
                  "h_index",
                  "h_index_fuente",
                  "creditos"
                ],
                "properties": {
                  "nombre": { "type": "string" },
                  "orcid": { "type": ["string", "null"] },
                  "afiliacion": { "type": ["string", "null"] },
                  "rol": {
                    "type": "string",
                    "enum": [
                      "autor",
                      "correspondencia",
                      "primer_autor",
                      "ultimo_autor",
                      "coautor"
                    ]
                  },
                  "h_index": { "type": ["integer", "null"], "minimum": 0 },
                  "h_index_fuente": {
                    "type": "string",
                    "enum": [
                      "openalex",
                      "semanticscholar",
                      "no_disponible"
                    ]
                  },
                  "creditos": {
                    "type": ["string", "null"],
                    "description": "Rol CRediT o descripción inferida"
                  }
                }
              }
            },
            "creditos_contribucion": {
              "type": ["string", "null"],
              "description": "Resumen CRediT del paper completo"
            },
            "open_access": { "type": ["boolean", "null"] },
            "notas": { "type": "string" }
          }
        },
        "relevancia_doctoral": { "type": "string" },
        "nivel_confianza": {
          "type": "string",
          "enum": ["alta", "media", "baja"]
        },
        "riesgos_sesgo": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
